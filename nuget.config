<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Hosting integrations published by the catalog and basket teams. -->
    <add key="github-lpichet" value="https://nuget.pkg.github.com/lpichet/index.json" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github-lpichet">
      <package pattern="EShop.*" />
    </packageSource>
  </packageSourceMapping>

  <!-- GitHub Packages requires authentication even for public packages.
       Credentials are intentionally NOT stored here: add them once to your
       user-level NuGet config (works in terminals AND IDE background restores).
       See "Run it" in README.md for the two-command setup.
       CI injects credentials into its workspace copy of this file (see ci.yml). -->
</configuration>
