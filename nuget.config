<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Hosting integrations published by the catalog and basket teams. -->
    <add key="github-lpichet" value="https://nuget.pkg.github.com/lpichet/index.json" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github-lpichet">
      <package pattern="EShop.*" />
    </packageSource>
  </packageSourceMapping>

  <!-- GitHub Packages requires authentication even for public packages.
       Credentials are intentionally NOT stored here: put them in your user-level
       NuGet config once (works in terminals AND IDE background restores):

         gh auth refresh -h github.com -s read:packages
         dotnet nuget add source https://nuget.pkg.github.com/lpichet/index.json \
           --name github-lpichet --username $(gh api user --jq .login) \
           --password $(gh auth token) --store-password-in-clear-text \
           --configfile ~/.nuget/NuGet/NuGet.Config

       CI injects credentials into its workspace copy of this file (see ci.yml). -->
</configuration>
