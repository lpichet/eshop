<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Hosting integrations published by the catalog and basket teams. -->
    <add key="github-lpichet" value="https://nuget.pkg.github.com/lpichet/index.json" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github-lpichet">
      <package pattern="EShop.*" />
    </packageSource>
  </packageSourceMapping>

  <!-- GitHub Packages requires authentication even for public packages.
       Locally:  export GITHUB_USERNAME=lpichet && export GITHUB_TOKEN=$(gh auth token)
       In CI:    provided automatically from the workflow. -->
  <packageSourceCredentials>
    <github-lpichet>
      <add key="Username" value="%GITHUB_USERNAME%" />
      <add key="ClearTextPassword" value="%GITHUB_TOKEN%" />
    </github-lpichet>
  </packageSourceCredentials>
</configuration>
